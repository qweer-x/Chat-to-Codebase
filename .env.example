# AUTO_SYNC Bridge Server 配置示例
# 复制本文件为 .env 后再按需修改。
# 注意：.env 不要上传到 GitHub。

# 本地项目根目录
# 留空时默认使用 bridge_server.py 启动时所在目录
AUTO_SYNC_PROJECT_ROOT=

# 本地服务地址
AUTO_SYNC_HOST=127.0.0.1
AUTO_SYNC_PORT=9999

# 是否启用 Git 自动提交
# true / false
AUTO_SYNC_GIT_ENABLED=false

# 是否在提交后自动 git push
# true / false
AUTO_SYNC_GIT_PUSH=false

# 是否在覆盖旧文件前自动备份
# true / false
AUTO_SYNC_BACKUP_ENABLED=true

# 日志目录
AUTO_SYNC_LOG_DIR=.auto_sync_logs